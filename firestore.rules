rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in [
          "shekohitler@gmail.com",
          "Martin.magdy109@gmail.com",
          "shadywaheed10101@gmail.com"
        ] ||
        request.auth.uid in [
          "ADMIN_UID_1",
          "ADMIN_UID_2"
        ]
      );
    }

    function canDelete() {
      return isSignedIn() && (
        request.auth.token.email in [
          "shekohitler@gmail.com"
        ] ||
        request.auth.uid in [
          "DELETE_UID_1"
        ]
      );
    }

    // كتابة لوحة الصلاحيات (settings/team) — غيّر الإيميل لمشرفك الرئيسي فقط
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email in [
        "shekohitler@gmail.com"
      ];
    }

    function canWriteHymnVisibility() {
      return !(request.resource.data.isExclusive == true) ||
        (isSuperAdmin() && request.resource.data.exclusiveOwnerUid == request.auth.uid);
    }

    match /hymns/{hymnId} {
      allow read: if true;
      allow create, update: if isAdmin() && canWriteHymnVisibility();
      allow delete: if canDelete();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
