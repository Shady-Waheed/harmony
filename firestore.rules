rules_version = '2';

// صلّح القواعد في الإنتاج: حصر الكتابة على المشرفين (Claims أو قائمة بريد ثابتة).
// حاليًا يسمح للمستخدمين المسجّلين بالقراءة/الكتابة للتطوير — راجع Firebase Console > Firestore > Rules.

service cloud.firestore {
  match /databases/{database}/documents {
    match /hymns/{hymnId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
